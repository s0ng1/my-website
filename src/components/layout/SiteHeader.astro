---
import Container from "./Container.astro";
import { siteConfig } from "../../data/site";
import { withBase } from "../../utils/paths";

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === "/") {
    return currentPath === "/";
  }

  return currentPath === href || currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-40 border-b border-line/70 bg-app/88 backdrop-blur-sm">
  <Container as="div" class="flex min-h-16 items-center justify-between gap-4">
    <a
      href={withBase("/")}
      class="inline-flex items-center text-sm font-semibold tracking-[0.18em] text-ink transition-colors duration-200 hover:text-accent"
    >
      {siteConfig.siteTitle}
    </a>

    <nav aria-label="主导航">
      <ul class="flex items-center gap-2 sm:gap-3">
        {siteConfig.navigation.map((item) => {
          const active = isActive(item.href);

          return (
            <li>
              <a
                href={withBase(item.href)}
                aria-current={active ? "page" : undefined}
                class:list={[
                  "inline-flex min-h-11 items-center rounded-full px-4 text-sm transition-colors duration-200",
                  active
                    ? "bg-accent-soft text-accent"
                    : "text-muted hover:text-ink",
                ]}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </Container>
</header>
