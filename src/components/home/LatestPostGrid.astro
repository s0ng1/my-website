---
import type { PostSummary } from "../../utils/content";
import PostCard from "../post/PostCard.astro";

interface Props {
  posts: PostSummary[];
}

const { posts } = Astro.props as Props;
---

<div class="grid gap-5 md:grid-cols-2">
  {posts.map((post) => (
    <PostCard post={post} />
  ))}
</div>
