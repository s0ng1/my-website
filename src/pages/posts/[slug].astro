---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/layout/Container.astro";
import PostHeader from "../../components/post/PostHeader.astro";
import PostPagination from "../../components/post/PostPagination.astro";
import PostToc from "../../components/post/PostToc.astro";
import { resolvePostCover } from "../../utils/media";
import { withBase } from "../../utils/paths";
import {
  getAdjacentPosts,
  getAllPosts,
  toPostSummary,
} from "../../utils/content";

export async function getStaticPaths() {
  const posts = await getAllPosts();

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const summary = toPostSummary(post);
const adjacentPosts = await getAdjacentPosts(post.slug);
const cover = resolvePostCover(summary);
---

<BaseLayout
  title={summary.title}
  description={summary.description}
  pathname={`/posts/${summary.slug}/`}
  image={cover.src}
  type="article"
  publishedTime={summary.pubDate}
  modifiedTime={summary.updatedDate ?? summary.pubDate}
>
  <section class="py-16 md:py-20">
    <Container width="narrow">
      <div class="space-y-10">
        <PostHeader
          title={summary.title}
          description={summary.description}
          pubDate={summary.pubDate}
          updatedDate={summary.updatedDate}
          category={summary.category}
          categoryLabel={summary.categoryLabel}
          tags={summary.tags}
        />

        <img
          src={withBase(cover.src)}
          alt={cover.alt}
          class="aspect-video w-full rounded-[1.7rem] border border-line/70 object-cover"
          loading="eager"
        />

        <PostToc headings={headings} />

        <article class="prose-article">
          <Content />
        </article>

        <PostPagination previous={adjacentPosts.previous} next={adjacentPosts.next} />
      </div>
    </Container>
  </section>
</BaseLayout>
